{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "type": "chrome",
            "request": "launch",
            "name": "WGL using",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Chat",
            "skipFiles": ["<node_internals>/**"],
            "program": "${workspaceFolder}/MyServer/server/server.js",
            "cwd": "${workspaceFolder}/MyServer/dist"
        },
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Game",
            "skipFiles": ["<node_internals>/**"],
            "program": "${workspaceFolder}/Artillery game/server/server.js",
            "cwd": "${workspaceFolder}/Artillery game/dist"
        }
    ]
}